# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Supabase — get from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudflare Worker proxy URL (optional — AI summaries fall back to direct if omitted)
VITE_PROXY_URL=https://feedbox-proxy.your-subdomain.workers.dev

# Anthropic API key for AI summaries (optional).
# Used as a fallback when no Worker/Edge Function is configured.
# ⚠️  VITE_ vars are bundled into the JS — safe for personal deployments,
#     but use a server-side secret (Supabase Edge Function) for public apps.
VITE_ANTHROPIC_KEY=sk-ant-api03-…
